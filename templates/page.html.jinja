<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page.title }}</title>
  <meta name="description" content="{{ page.description }}">
  <link rel="canonical" href="{{ site_url }}/{{ page.slug }}.html">
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ page.title }}">
  <meta property="og:description" content="{{ page.description }}">
  <meta property="og:url" content="{{ site_url }}/{{ page.slug }}.html">
  <meta property="og:site_name" content="Vincent Bastille Remixes">
  <style>
    :root { --bg:#090c16; --card:#131a2b; --text:#f2f4ff; --muted:#a8b0c8; --accent:#78e4d4; --maxw:980px; }
    * { box-sizing:border-box; }
    body { margin:0; background:radial-gradient(circle at top right,#1e2944 0%,var(--bg) 45%); color:var(--text); font-family:Inter,system-ui,sans-serif; line-height:1.7; }
    .wrap { max-width:var(--maxw); margin:0 auto; padding:20px; }
    .hero,.card { background:linear-gradient(160deg,rgba(255,255,255,.03),rgba(255,255,255,.01)); border:1px solid rgba(255,255,255,.1); border-radius:14px; padding:22px; margin:14px 0; }
    h1,h2,h3 { line-height:1.25; }
    .muted { color:var(--muted); }
    .btn { display:inline-block; text-decoration:none; font-weight:700; border-radius:10px; padding:10px 14px; margin-right:8px; }
    .btn-primary { background:var(--accent); color:#041016; }
    .btn-alt { border:1px solid #f7c56d; color:#ffe5b0; }
    a { color:#9ee8ff; }
  </style>
  <script type="application/ld+json">{{ schema_json }}</script>
</head>
<body>
  <main class="wrap">
    <section class="hero">
      <p>Vincent Bastille · Remix Legacy</p>
      <h1>{{ heading }}</h1>
      <p class="muted">{{ page.description }}</p>
      <a class="btn btn-primary" href="{{ cta_url }}">Listen Vincent Bastille Remix</a>
      <a class="btn btn-alt" href="{{ cta_url }}">Discover full remix catalog</a>
    </section>

    <article class="card">
      <h2>Ultimate remix legacy introduction</h2>
      <p>{{ body.intro }}</p>
    </article>

    {% for section in body.sections %}
    <section class="card">
      <h2>{{ section.title }}</h2>
      {% for paragraph in section.paragraphs %}
      <p>{{ paragraph }}</p>
      {% endfor %}
    </section>
    {% endfor %}

    <section class="card">
      <h2>Similar remix pages to explore</h2>
      <h3>Internal remix cluster</h3>
      <ul>
        {% for link in related %}
        <li><a href="/{{ link.slug }}.html">{{ link.anchor }}</a></li>
        {% endfor %}
      </ul>
    </section>

    <section class="card">
      <h2>FAQ</h2>
      {% for item in body.faq %}
      <h3>{{ item.q }}</h3>
      <p>{{ item.a }}</p>
      {% endfor %}
    </section>
  </main>
</body>
</html>
