<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page.title }}</title>
  <meta name="description" content="{{ page.description }}">
  <link rel="canonical" href="{{ site_url }}/{{ page.slug }}.html">
  <style>
    :root {
      --bg: #090c16;
      --bg-card: #131a2b;
      --text: #f2f4ff;
      --muted: #a8b0c8;
      --accent: #78e4d4;
      --accent-2: #f7c56d;
      --maxw: 960px;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: radial-gradient(circle at top right, #1e2944 0%, var(--bg) 45%);
      color: var(--text);
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      line-height: 1.7;
    }
    .wrap { max-width: var(--maxw); margin: 0 auto; padding: 20px; }
    .hero, .card {
      background: linear-gradient(160deg, rgba(255,255,255,.03), rgba(255,255,255,.01));
      border: 1px solid rgba(255,255,255,.09);
      border-radius: 16px;
      padding: 24px;
      margin: 14px 0;
    }
    .kicker { color: var(--accent); text-transform: uppercase; letter-spacing: .08em; font-size: .78rem; }
    h1, h2 { line-height: 1.2; margin-top: 0; }
    p { color: #e7ebff; }
    .muted { color: var(--muted); }
    .cta-row { display: flex; flex-wrap: wrap; gap: 10px; margin: 14px 0 4px; }
    .btn {
      display: inline-block;
      text-decoration: none;
      font-weight: 700;
      border-radius: 10px;
      padding: 10px 14px;
      border: 1px solid transparent;
    }
    .btn-primary { background: var(--accent); color: #041016; }
    .btn-alt { background: transparent; border-color: var(--accent-2); color: #ffe5b0; }
    ul { padding-left: 1.2rem; }
    a { color: #9ee8ff; }
    footer { margin: 24px 0 10px; color: var(--muted); font-size: .94rem; }
    @media (max-width: 720px) {
      .hero, .card { padding: 18px; }
      h1 { font-size: 1.6rem; }
    }
  </style>
  <script type="application/ld+json">{{ schema_json }}</script>
</head>
<body>
  <main class="wrap">
    <section class="hero">
      <p class="kicker">Vincent Bastille · Remix Archive</p>
      <h1>{{ heading }}</h1>
      <p class="muted">{{ page.description }}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="{{ cta_url }}">Listen to Vincent Bastille remixes now</a>
        <a class="btn btn-alt" href="{{ cta_url }}">Open the full remix catalog</a>
      </div>
    </section>

    <article class="card">
      {% for paragraph in paragraphs %}
      <p>{{ paragraph }}</p>
      {% endfor %}
    </article>

    <section class="card">
      <h2>Explore more remix directions</h2>
      <ul>
        {% for link in related %}
        <li><a href="/{{ link.slug }}.html">{{ link.anchor }}</a></li>
        {% endfor %}
      </ul>
    </section>

    <footer>
      <p>Still digging? Head back to <a href="{{ cta_url }}">remixes.vincentbastille.online</a> for the complete experience.</p>
    </footer>
  </main>
</body>
</html>
