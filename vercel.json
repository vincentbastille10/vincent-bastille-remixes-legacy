{
  "version": 2,
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/api/sitemap.xml"
    },
    {
      "src": "/sitemap",
      "dest": "/sitemap.xml",
      "status": 301
    },
    {
      "src": "/remixes/(.*)",
      "dest": "/remixes/$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
