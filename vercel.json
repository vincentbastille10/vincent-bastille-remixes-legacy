{
  "version": 2,
  "routes": [
    {
      "src": "/sitemap",
      "dest": "/sitemap.xml",
      "status": 301
    },
    {
      "handle": "filesystem"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    }
  ]
}
