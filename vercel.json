{
  "version": 2,
  "routes": [
    {
      "src": "/sitemap",
      "dest": "/sitemap.xml",
      "status": 301
    },
    {
      "src": "/remixes/(.*)",
      "dest": "/remixes/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}
