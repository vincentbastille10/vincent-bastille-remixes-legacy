{
  "version": 2,
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/$", "dest": "/remixes/index.html" },

    { "src": "^/remixes/(.*\\.html)$", "dest": "/remixes/$1" },

    { "src": "^/assets/(.*)$", "dest": "/assets/$1" },
    { "src": "^/static/(.*)$", "dest": "/static/$1" },

    { "src": "^/(.*\\.html)$", "dest": "/$1" }
  ]
}
